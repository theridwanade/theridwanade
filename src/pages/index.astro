---
import Layout from '../layouts/Layout.astro';
import { getLatestPosts, getFeaturedPost, calculateReadingTime } from '@/lib/post-utils';
import path from 'path';

const year = new Date().getFullYear();
const postsDir = path.join(process.cwd(), 'src/contents/posts');
const latestPosts = getLatestPosts(postsDir, 3);
const featuredPost = getFeaturedPost(postsDir);

// Helper to extract image from wikilink
const extractImage = (imageStr: string) => {
  if (!imageStr) return null;
  const match = imageStr.match(/\[\[(.+?)\]\]/);
  return match ? `/blogs/${match[1]}` : imageStr;
};
---

<Layout>
    <section class="flex flex-col-reverse md:flex-row items-center justify-between min-h-[80vh] px-4 max-w-5xl mx-auto gap-8 md:gap-12">
        
        {/* Left Side: Text */}
        <div class="flex flex-col items-start max-w-2xl">
            <span class="text-lg font-medium text-blue-600 mb-4">
                Hi,
            </span>

            <h1 class="text-5xl md:text-7xl font-bold text-gray-900 tracking-tight mb-4">
                I am Ridwan Oyeniyi.
            </h1>

            <h2 class="text-3xl md:text-5xl font-bold text-gray-400 mb-6">
                Software & Hardware Developer.
            </h2>

            <p class="text-xl text-gray-600 mb-8">
                I build software and hardware.
            </p>

            <div class="flex flex-wrap gap-4">
                <a 
                    href="/contact" 
                    class="px-6 py-3 bg-gray-900 text-white font-medium rounded-lg hover:bg-gray-800 transition-colors"
                >
                    Get in touch
                </a>
                <a 
                    href="/blogs" 
                    class="px-6 py-3 border border-gray-300 text-gray-700 font-medium rounded-lg hover:bg-gray-50 transition-colors"
                >
                    Read my notes
                </a>
            </div>
        </div>

        {/* Right Side: Portrait Image */}
        <div class="shrink-0">
            <img 
                src="/me.jpg" 
                alt="Ridwan Oyeniyi" 
                class="w-40 md:w-56 aspect-5/7 rounded-xl object-cover shadow-md"
            />
        </div>

    </section>

    {/* Featured Blog Section */}
    {featuredPost && (
      <section class="max-w-5xl mx-auto px-4 py-16">
        <div class="mb-4">
          <span class="text-sm font-semibold text-blue-600 uppercase tracking-wide">Featured</span>
        </div>
        <div class="grid md:grid-cols-2 gap-8 items-center bg-gray-50 rounded-xl overflow-hidden">
          {extractImage(featuredPost.frontmatter?.image) && !(featuredPost.frontmatter?.hideCoverImage === true || featuredPost.frontmatter?.hideCoverImage === 'true') && (
            <img 
              src={extractImage(featuredPost.frontmatter?.image)} 
              alt={featuredPost.frontmatter?.imageAlt || featuredPost.frontmatter?.title}
              class="h-72 object-cover"
            />
          )}
          <div class="p-6 md:p-8">
            <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-3">
              {featuredPost.frontmatter?.title || featuredPost.slug}
            </h2>
            {featuredPost.frontmatter?.description && (
              <p class="text-gray-600 mb-4 line-clamp-3">
                {featuredPost.frontmatter.description}
              </p>
            )}
            <div class="flex items-center gap-2 text-sm text-gray-500 mb-6">
              {featuredPost.frontmatter?.date && (
                <span>
                  {new Date(featuredPost.frontmatter.date).toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric'
                  })}
                </span>
              )}
              {featuredPost.frontmatter?.date && calculateReadingTime(featuredPost.content) && <span>•</span>}
              {calculateReadingTime(featuredPost.content) && <span>{calculateReadingTime(featuredPost.content)} min read</span>}
            </div>
            <a 
              href={`/blogs/${featuredPost.slug}`}
              class="inline-block px-6 py-2 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition-colors"
            >
              Read Article
            </a>
          </div>
        </div>
      </section>
    )}

    {/* Latest Blogs Section */}
    {latestPosts.length > 0 && (
      <section class="max-w-5xl mx-auto px-4 py-16">
        <div class="mb-12">
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Latest Articles</h2>
          <p class="text-gray-600">Explore my latest thoughts and insights</p>
        </div>
        <div class="grid md:grid-cols-3 gap-8">
          {latestPosts.map((post) => {
            const postImage = extractImage(post.frontmatter?.image);
            const hideCover = post.frontmatter?.hideCoverImage === true || post.frontmatter?.hideCoverImage === 'true';
            
            return (
              <a 
                href={`/blogs/${post.slug}`}
                class="group bg-white border border-gray-200 rounded-lg overflow-hidden hover:shadow-lg hover:border-gray-300 transition-all duration-300"
              >
                {postImage && !hideCover && (
                  <div class="h-48 overflow-hidden bg-gray-100">
                    <img 
                      src={postImage} 
                      alt={post.frontmatter?.imageAlt || post.frontmatter?.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                    />
                  </div>
                )}
                <div class="p-6">
                  <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-blue-600 transition-colors">
                    {post.frontmatter?.title || post.slug}
                  </h3>
                  {post.frontmatter?.description && (
                    <p class="text-gray-600 text-sm mb-4 line-clamp-2">
                      {post.frontmatter.description}
                    </p>
                  )}
                  <div class="flex items-center justify-between text-xs text-gray-500">
                    <div class="flex items-center gap-2">
                      {post.frontmatter?.date && (
                        <span>
                          {new Date(post.frontmatter.date).toLocaleDateString('en-US', {
                            year: 'numeric',
                            month: 'short',
                            day: 'numeric'
                          })}
                        </span>
                      )}
                      {post.frontmatter?.date && calculateReadingTime(post.content) && <span>•</span>}
                      {calculateReadingTime(post.content) && <span>{calculateReadingTime(post.content)} min read</span>}
                    </div>
                    {post.frontmatter?.tags && (
                      <span class="px-2 py-1 bg-blue-100 text-blue-700 rounded-full">
                        {Array.isArray(post.frontmatter.tags) ? post.frontmatter.tags[0] : post.frontmatter.tags}
                      </span>
                    )}
                  </div>
                </div>
              </a>
            );
          })}
        </div>
        <div class="mt-12 text-center">
          <a 
            href="/blogs"
            class="inline-block px-8 py-3 border-2 border-gray-900 text-gray-900 font-semibold rounded-lg hover:bg-gray-900 hover:text-white transition-colors"
          >
            View All Articles
          </a>
        </div>
      </section>
    )}


    <div class="max-w-5xl mx-auto px-4 py-8 flex flex-col md:flex-row justify-between items-center gap-4">
        
        {/* Left: Copyright */}
        <div class="text-gray-400 text-sm">
            &copy; {year} Ridwan Oyeniyi.
        </div>

        {/* Right: Social Icons (SVG) */}
        <div class="flex gap-6 items-center">
            
            {/* Twitter / X */}
            <a href="https://x.com/theridwanade" target="_blank" aria-label="Twitter" class="text-gray-400 hover:text-black transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 4l11.733 16h4.267l-11.733 -16z" />
                    <path d="M4 20l6.768 -6.768m2.46 -2.46l6.772 -6.772" />
                </svg>
            </a>

            {/* GitHub */}
            <a href="https://github.com/theridwanade" target="_blank" aria-label="GitHub" class="text-gray-400 hover:text-black transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
                    <path d="M9 18c-4.51 2-5-2-7-2" />
                </svg>
            </a>

            {/* Email */}
            <a href="mailto:ridwan@theridwanade.me" aria-label="Email" class="text-gray-400 hover:text-black transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect width="20" height="16" x="2" y="4" rx="2" />
                    <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
                </svg>
            </a>

        </div>
    </div>
</footer>
</Layout>