---
import Layout from '@/layouts/Layout.astro';
import { LinkedMentions } from '@/components/LinkedMentions';
import { getAllPosts, markdownToHtml } from '@/lib/post-utils';
import path from 'path';

export async function getStaticPaths() {
  const postsDir = path.join(process.cwd(), 'src/contents/posts');
  const posts = getAllPosts(postsDir);
  return posts.map((post) => ({ params: { slug: post.slug }, props: post }));
}

const { postId, frontmatter, content } = Astro.props;
const htmlContent = markdownToHtml(content);

// Extract image path from wikilink format [[attachments/image.png]] or use direct path
const imageMatch = frontmatter?.image?.match(/\[\[(.+?)\]\]/);
const imagePath = imageMatch ? `/blogs/${imageMatch[1]}` : frontmatter?.image;
const hideCover = frontmatter?.hideCoverImage === true || frontmatter?.hideCoverImage === 'true';
---

<Layout>
  <article class="max-w-4xl mx-auto px-4 py-8">
    {/* Header */}
    <header class="mb-8">
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
        {frontmatter.title || postId}
      </h1>

      {frontmatter.description && (
        <p class="text-xl text-gray-600 mb-4">{frontmatter.description}</p>
      )}

      {frontmatter.date && (
        <time class="text-sm text-gray-500">
          {new Date(frontmatter.date).toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </time>
      )}

      {frontmatter.tags && (
        <div class="flex flex-wrap gap-2 mt-4">
          {(Array.isArray(frontmatter.tags) ? frontmatter.tags : [frontmatter.tags]).map((tag: string) => (
            <span class="px-3 py-1 text-sm bg-gray-100 text-gray-700 rounded-full">{tag}</span>
          ))}
        </div>
      )}
    </header>

    {/* Featured Image */}
    {imagePath && !hideCover && (
      <div class="mb-8">
        <img 
          src={imagePath} 
          alt={frontmatter?.imageAlt || frontmatter?.title || 'Featured image'}
          class="w-full h-auto rounded-lg shadow-md"
        />
      </div>
    )}

    {/* Content */}
    <div class="prose prose-lg max-w-none" set:html={htmlContent} />

    {/* Linked Mentions Section */}
    <div class="mt-16">
      <LinkedMentions postId={postId} client:load />
    </div>
  </article>
</Layout>

<style is:global>
  /* Base prose styles */
  article .prose {
    color: rgb(31 41 55);
    line-height: 1.75;
    font-size: 1.125rem;
  }

  /* Typography */
  article .prose h1 {
    font-size: 2.25rem;
    font-weight: 700;
    margin-top: 2.5rem;
    margin-bottom: 1.25rem;
    color: rgb(17 24 39);
    line-height: 1.2;
  }

  article .prose h2 {
    font-size: 1.875rem;
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: 1rem;
    color: rgb(17 24 39);
    line-height: 1.3;
  }

  article .prose h3 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-top: 1.75rem;
    margin-bottom: 0.75rem;
    color: rgb(17 24 39);
    line-height: 1.4;
  }

  article .prose h4 {
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    color: rgb(31 41 55);
  }

  article .prose h5, article .prose h6 {
    font-size: 1.125rem;
    font-weight: 600;
    margin-top: 1.25rem;
    margin-bottom: 0.5rem;
    color: rgb(31 41 55);
  }

  /* Paragraphs and text */
  article .prose p {
    margin-bottom: 1.25rem;
    line-height: 1.75;
  }

  article .prose strong {
    font-weight: 700;
    color: rgb(17 24 39);
  }

  article .prose em {
    font-style: italic;
  }

  article .prose a {
    color: rgb(37 99 235);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
    transition: color 0.2s;
  }

  article .prose a:hover {
    color: rgb(29 78 216);
  }

  /* Lists */
  article .prose ul, article .prose ol {
    margin-bottom: 1.25rem;
    margin-left: 1.75rem;
    padding-left: 0.5rem;
  }

  article .prose ul {
    list-style-type: disc;
  }

  article .prose ol {
    list-style-type: decimal;
  }

  article .prose li {
    margin-bottom: 0.5rem;
    line-height: 1.75;
  }

  article .prose li > ul, article .prose li > ol {
    margin-top: 0.5rem;
    margin-bottom: 0.5rem;
  }

  /* Code */
  article .prose code {
    background-color: rgb(243 244 246);
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-size: 0.875em;
    font-family: 'Courier New', Courier, monospace;
    color: rgb(220 38 38);
    font-weight: 500;
  }

  article .prose pre {
    background-color: rgb(31 41 55);
    color: rgb(243 244 246);
    padding: 1.25rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
    margin-top: 1.5rem;
    line-height: 1.625;
  }

  article .prose pre code {
    background-color: transparent;
    padding: 0;
    border-radius: 0;
    color: inherit;
    font-size: 0.875rem;
    font-weight: 400;
  }

  /* Blockquotes */
  article .prose blockquote {
    border-left: 4px solid rgb(229 231 235);
    padding-left: 1rem;
    margin-left: 0;
    margin-right: 0;
    margin-top: 1.5rem;
    margin-bottom: 1.5rem;
    color: rgb(75 85 99);
    font-style: italic;
  }

  article .prose blockquote p {
    margin-bottom: 0.75rem;
  }

  /* Images */
  article .prose img {
    border-radius: 0.5rem;
    margin-top: 1.5rem;
    margin-bottom: 1.5rem;
    max-width: 100%;
    height: auto;
  }

  /* Multi-image grid layouts */
  article .prose .image-grid-2,
  article .prose .image-grid-3,
  article .prose .image-grid-4 {
    display: grid;
    gap: 1rem;
    margin-top: 1.5rem;
    margin-bottom: 1.5rem;
  }

  article .prose .image-grid-2 {
    grid-template-columns: repeat(2, 1fr);
  }

  article .prose .image-grid-3 {
    grid-template-columns: repeat(3, 1fr);
  }

  article .prose .image-grid-4 {
    grid-template-columns: repeat(4, 1fr);
  }

  article .prose .image-grid-2 img,
  article .prose .image-grid-3 img,
  article .prose .image-grid-4 img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    margin: 0;
    aspect-ratio: 4/3;
  }

  /* Horizontal rules */
  article .prose hr {
    border: 0;
    border-top: 1px solid rgb(229 231 235);
    margin-top: 2rem;
    margin-bottom: 2rem;
  }

  /* Tables */
  article .prose table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 1.5rem;
    margin-bottom: 1.5rem;
  }

  article .prose th, article .prose td {
    padding: 0.75rem;
    border: 1px solid rgb(229 231 235);
    text-align: left;
  }

  article .prose th {
    background-color: rgb(249 250 251);
    font-weight: 600;
  }

  article .prose tr:nth-child(even) {
    background-color: rgb(249 250 251);
  }

  /* Task lists */
  article .prose input[type="checkbox"] {
    margin-right: 0.5rem;
  }

  /* Mobile responsive */
  @media (max-width: 768px) {
    article .prose {
      font-size: 1rem;
    }

    article .prose h1 {
      font-size: 1.875rem;
    }

    article .prose h2 {
      font-size: 1.5rem;
    }

    article .prose h3 {
      font-size: 1.25rem;
    }

    /* Stack images on mobile */
    article .prose .image-grid-2,
    article .prose .image-grid-3,
    article .prose .image-grid-4 {
      grid-template-columns: 1fr;
    }
  }
</style>
